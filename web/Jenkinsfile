pipeline {
    agent any

    environment {
        MAVEN_HOME = tool 'Maven' //Name the tool correctly should match Jenkin tool name
        PATH = "${MAVEN_HOME}/bin:${env.PATH}"
    }

    stages {

        stage('Compile Stage') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Testing Stage') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Dependency Check') {
            steps {
                withCredentials([string(credentialsId: 'nvd-api-key', variable: 'NVD_KEY')]) {
                    sh '''
                        /opt/dependency-check/bin/dependency-check.sh \
                            --scan ./ \
                            --exclude "**/node_modules/**" \
                            --format XML \
                            --format HTML \
                            --out ./dependency-check-report \
                            --data /opt/dependency-check/data \
                            --nvdApiKey $NVD_KEY \
                            --prettyPrint
                    ''' //--scan <target-path> 
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('Sonar-Scan') {
                    sh '''
                        mvn sonar:sonar \
                            -Dsonar.projectKey=openobserve \
                            -Dsonar.projectName="Open Observe" \
                            -Dsonar.sources=web/src \
                            -Dsonar.javascript.node.maxspace=4096 \
                            -Dsonar.exclusions=**/node_modules/**,**/*.test.*,**/*.spec.*,**/test_logs.json,**/dist/**,**/build/**,**/__tests__/**,**/*.min.js,**/*.d.ts,**/coverage/**
                    ''' //source should be path to scan 
                }
            }
        }

        
        stage('Trivy Scan') {
    steps {
        sh '''
            mkdir -p trivy-report

            # Force UTF-8 + disable colors for clean output
            export LANG=en_US.UTF-8
            export LC_ALL=en_US.UTF-8
            export TRIVY_NO_COLOR=true
            export TRIVY_DISABLE_VEX_NOTICE=true

            set +e

            # --- Vulnerability scan ---
            trivy fs ./ \
                --scanners vuln \
                --severity HIGH,CRITICAL \
                --no-progress \
                --quiet \
                --format table \
                --output trivy-report/trivy-vuln-report.txt

            # --- Misconfig scan ---
            trivy fs ./ \
                --scanners misconfig \
                --severity HIGH,CRITICAL \
                --no-progress \
                --quiet \
                --format table \
                --output trivy-report/trivy-misconfig-report.txt

            # --- Secret scan ---
            trivy fs ./ \
                --scanners secret \
                --no-progress \
                --quiet \
                --format table \
                --output trivy-report/trivy-secret-report.txt

            # --- Combined JSON for archiving ---
            trivy fs ./ \
                --scanners vuln,secret,misconfig \
                --severity HIGH,CRITICAL \
                --no-progress \
                --quiet \
                --format json \
                --output trivy-report/trivy-full-report.json

            set -e

            echo "============================================"
            echo "         TRIVY VULNERABILITY REPORT         "
            echo "============================================"
            cat trivy-report/trivy-vuln-report.txt

            echo ""
            echo "============================================"
            echo "        TRIVY MISCONFIGURATION REPORT       "
            echo "============================================"
            cat trivy-report/trivy-misconfig-report.txt

            echo ""
            echo "============================================"
            echo "            TRIVY SECRET REPORT             "
            echo "============================================"
            cat trivy-report/trivy-secret-report.txt
        '''
    }
}
        
        stage('Package Stage') {
            steps {
                sh 'mvn package'
            }
        }

    }

    post {
        always {
            //Depenency check report
            dependencyCheckPublisher pattern: 'dependency-check-report/dependency-check-report.xml'
            archiveArtifacts artifacts: 'dependency-check-report/**', fingerprint: true
            //trivy report
            archiveArtifacts artifacts: 'trivy-report/**', fingerprint: true
            
            echo 'Pipeline finished.'
        }
        success {
            echo '✅ All stages passed successfully!'
        }
        unstable {
            echo '⚠️ Pipeline completed with warnings.'
        }
        failure {
            echo '❌ Pipeline failed. Check the logs above.'
        }
    }
}
