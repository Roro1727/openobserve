pipeline {
    agent any

    tools {
      // Optional if using Node scripts locally
        snyk 'SnykLatest'     // Your configured Snyk installation
    }

        environment {
        MAVEN_HOME = tool 'maven_3_5_0'
        PATH = "${MAVEN_HOME}/bin:${env.PATH}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Compile Stage') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Testing Stage') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Snyk Security Scan') {
    steps {
        dir('web') {
            script {
                sh '''
                snyk test --json --severity-threshold=high > snyk_report.json || true
                snyk-to-html -i snyk_report.json -o snyk_report.html
                '''
            }
            archiveArtifacts artifacts: 'web/snyk_report.html', fingerprint: true
        }
    }
}


        stage('SonarQube Analysis') {
            steps {
               withSonarQubeEnv('SonarQube') {
                    sh '''
                        mvn sonar:sonar \
                          -Dsonar.projectKey=jenkins-integration \
                          -Dsonar.projectName="Jenkins Integration" \
                          -Dsonar.sources=src/main/java \
                          -Dsonar.tests=src/test/java \
                          -Dsonar.java.binaries=target/classes
                    ''' // Replace with your SonarQube scanner step
               }
            }
        }

        stage('Quality Gate') {
            steps {
                echo 'Checking Quality Gate...'


            }
        }

        stage('Package Stage') {
            steps {
                echo 'Packaging application...'
            }
        }

    }

    post {
        always {
            echo 'Pipeline finished. Check Snyk report for vulnerabilities.'
        }
    }
}
