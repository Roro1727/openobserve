//                             -Dsonar.javascript.node.maxspace=4096 \
//                             -Dsonar.exclusions=**/node_modules/**,**/*.test.*,**/*.spec.*,**/test_logs.json,**/dist/**,**/build/**,**/__tests__/**,**/*.min.js,**/*.d.ts,**/coverage/**
//                     ''' //source should be path to scan 
//                 }
//             }
//         }

        
//         stage('Trivy Scan') {
//     steps {
//         sh '''
//             mkdir -p trivy-report

//             set +e

//             trivy fs ./ \
//                 --no-progress \
//                 --quiet \
//                 --format table \
//                 --output trivy-report/trivy-report.txt

//             set -e

//             iconv -f UTF-8 -t ASCII//TRANSLIT trivy-report/trivy-report.txt \
//                 > trivy-report/trivy-clean.txt
//             mv trivy-report/trivy-clean.txt trivy-report/trivy-report.txt

//         '''
//     }
// }
        



        stage('Compile Stage') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Testing Stage') {
            steps {
                sh 'mvn test'
            }
        }
    //     stage('OWASP ZAP Scan') {
    // steps {
    //     sh '''
    //         mkdir -p /tmp/zap-report

    //         set +e

    //         /opt/zaproxy/zap.sh -cmd \
    //             -quickurl https://172.16.14.71/ \
    //             -quickprogress \
    //             -quickout /tmp/zap-report/zap-report.html

    //         ZAP_EXIT=$?

    //         set -e

    //         # Quote the path to handle spaces in workspace name
    //         mkdir -p "/var/lib/jenkins/workspace/DevOps Pipeline@2/zap-report"
    //         cp -r /tmp/zap-report/. "/var/lib/jenkins/workspace/DevOps Pipeline@2/zap-report/"

    //         echo "============================================"
    //         echo "         ZAP SCAN COMPLETE"
    //         echo "============================================"

    //         if [ -f /tmp/zap-report/zap-report.html ]; then
    //             echo "✅ ZAP report generated successfully"
    //         else
    //             echo "⚠️ ZAP exited with code: $ZAP_EXIT"
    //         fi
    //     '''
    // }
    
    //}

        
        stage('Package Stage') {
            steps {
                sh 'mvn package'
            }
        }

    }

    post {
        always {
            //Depenency check report
            dependencyCheckPublisher pattern: 'dependency-check-report/dependency-check-report.xml'
            archiveArtifacts artifacts: 'dependency-check-report/**', fingerprint: true
            //trivy report
            archiveArtifacts artifacts: 'trivy-report/**', fingerprint: true
            //Pre-commit report
            archiveArtifacts artifacts: 'truffle_report.txt', fingerprint: true
            //ZAP report
            archiveArtifacts artifacts: 'zap-report/**', fingerprint: true

            
            echo 'Pipeline finished.'
        }
        success {
            echo '✅ All stages passed successfully!'
        }
        unstable {
            echo '⚠️ Pipeline completed with warnings.'
        }
        failure {
            echo '❌ Pipeline failed. Check the logs above.'
        }
    }
}
