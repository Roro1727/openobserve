        //                     --format HTML \
        //                     --out ./dependency-check-report \
        //                     --data /opt/dependency-check/data \
        //                     --nvdApiKey $NVD_KEY \
        //                     --prettyPrint
        //             ''' //--scan <target-path> 
        //         }
        //     }
        // }

        // stage('SonarQube Analysis') {
        //     steps {
        //         withSonarQubeEnv('Sonar-Scan') {
        //             sh '''
        //                 mvn sonar:sonar \
        //                     -Dsonar.projectKey=openobserve \
