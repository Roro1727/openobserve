pipeline {
    agent any

    environment {
        MAVEN_HOME = tool 'Maven' //Name the tool correctly should match Jenkin tool name
        PATH = "${MAVEN_HOME}/bin:${env.PATH}"
    }

    stages {

        stage('Pre-Commit') {
    steps {
        sh 'pre-commit trufflehog run --files ./ --show-diff-on-failure | tee pre-commit-report.txt'
        sh 'cat pre-commit-report.txt'
    }
}


        stage('Compile Stage') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Testing Stage') {
            steps {
                sh 'mvn test'
            }
        }

        // stage('Dependency Check') {
        //     steps {
