pipeline {
    agent any

    environment {
        MAVEN_HOME = tool 'Maven' //Change name to Maven's Name in Jenkins tools
        PATH = "${MAVEN_HOME}/bin:${env.PATH}"
    }

    stages {

        stage('Compile Stage') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Testing Stage') {
            steps {
                sh 'mvn test'
            }
        }
        
    stage('Dependency Check') {
            steps {
                withCredentials([string(credentialsId: 'nvd-api-key', variable: 'NVD_KEY')]) {
                    sh '''
                        /opt/dependency-check/bin/dependency-check.sh \
                            --scan ./web \
                            --exclude "**/node_modules/**" \
                            --format XML \
                            --format HTML \
                            --out ./dependency-check-report \
                            --data /opt/dependency-check/data \
                            --nvdApiKey $NVD_KEY \
                            --prettyPrint
                    '''
                }
            }
        }
    

        stage('SonarQube Analysis') {
    steps {
        withSonarQubeEnv('Sonar-Scan') { //Change name to Jenkin Sonarqube Tool Name
            sh '''
                mvn sonar:sonar \
                  -Dsonar.projectKey=openobserve \
                  -Dsonar.projectName="Open Observe" \
                  -Dsonar.sources=web/src \
                  -Dsonar.javascript.node.maxspace=4096 \
                  -Dsonar.exclusions=**/node_modules/**,**/*.test.*,**/*.spec.*,**/test_logs.json,**/dist/**,**/build/**,**/__tests__/**,**/*.min.js,**/*.d.ts,**/coverage/**
            '''
        }
    }
}

    

        stage('Package Stage') {
            steps {
                sh 'mvn package'
            }
        }

    }

    post {
        always {
            // Publish the HTML report inside Jenkins
            publishHTML(target: [
                allowMissing         : false,
                alwaysLinkToLastBuild: true,
                keepAll              : true,
                reportDir            : 'dependency-check-report',
                reportFiles          : 'dependency-check-report.html',
                reportName           : 'OWASP Dependency Check Report'
            ])

            // Archive XML report as artifact
            archiveArtifacts artifacts: 'dependency-check-report/**', fingerprint: true
        }
        success {
            echo '✅ Dependency Check passed!'
        }
        failure {
            echo '❌ Dependency Check failed. Review the report.'
}
    }
}


